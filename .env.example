# MTXfoil — copy to .env and adjust

# Dashboard / Payload (required in production)
PAYLOAD_SECRET=change-me-to-a-long-random-string-at-least-32-chars
DATABASE_URL=postgres://mtxfoil:mtxfoil@postgres:5432/mtxfoil
POSTGRES_USER=mtxfoil
POSTGRES_PASSWORD=mtxfoil
POSTGRES_DB=mtxfoil

# Public stream domain (used in URL templates)
PUBLIC_STREAM_DOMAIN=localhost

# MediaMTX internal URLs (Docker network only — do not expose 9997/9998 to host)
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_METRICS_URL=http://mediamtx:9998
MEDIAMTX_CONFIG_PATH=/app/mediamtx-config/mediamtx.yml
MEDIAMTX_BACKUP_DIR=/app/mediamtx-config/backups

# MediaMTX internal auth (written to mediamtx.yml on config apply — change in production)
MEDIAMTX_INTERNAL_USER=mtxfoil
MEDIAMTX_INTERNAL_PASS=mtxfoil

# Media ports (host-published)
SRT_PORT=8890
RTMP_PORT=1935
RTMPS_PORT=1936
RTSP_PORT=8554
HLS_PORT=8888
WEBRTC_HTTP_PORT=8889
WEBRTC_ICE_PORT=8189

# URL templates
HLS_BASE_URL=http://localhost:8888
WEBRTC_BASE_URL=http://localhost:8889

# Playback token signing (required in production — 32+ chars, separate from PAYLOAD_SECRET)
PLAYBACK_TOKEN_SECRET=change-me-playback-token-secret-at-least-32-chars

# Redis / worker (MVP3)
# Dev: no password. Production compose requires REDIS_PASSWORD.
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change-me-redis-password
WORKER_CONCURRENCY=2

# Node
NODE_ENV=development
