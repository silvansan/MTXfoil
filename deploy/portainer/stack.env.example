# Portainer stack environment — copy into Portainer Advanced mode
#
# =============================================================================
# REQUIRED — deploy fails or dashboard returns HTTP 500 if any are missing,
# weak, or still set to mtxfoil / CHANGE_ME placeholders.
# Generate secrets on your machine:
#   openssl rand -hex 16          # passwords (32 hex chars)
#   openssl rand -hex 32          # PAYLOAD_SECRET / PLAYBACK_TOKEN_SECRET (64 hex chars)
# =============================================================================

# --- Secrets (all required) ---
PAYLOAD_SECRET=CHANGE_ME_32_PLUS_CHARACTER_RANDOM_STRING
PLAYBACK_TOKEN_SECRET=CHANGE_ME_PLAYBACK_SECRET_32_PLUS_CHARS
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Unique MediaMTX control-plane user — do NOT use mtxfoil, admin, mediamtx, etc.
# (rejected at dashboard startup in production)
MEDIAMTX_INTERNAL_USER=REPLACE_WITH_UNIQUE_MTX_USERNAME
MEDIAMTX_INTERNAL_PASS=CHANGE_ME_MEDIAMTX_INTERNAL_PASSWORD

# --- Public URLs (all required; use https:// after TLS) ---
PUBLIC_STREAM_DOMAIN=stream.example.com
DASHBOARD_PUBLIC_URL=https://mtxfoil.example.com
HLS_BASE_URL=https://stream.example.com/hls
WEBRTC_BASE_URL=https://stream.example.com/webrtc

# --- Optional defaults ---
POSTGRES_USER=mtxfoil
POSTGRES_DB=mtxfoil

# Image tags (default PORTAINER_STACK.yml builds dashboard/worker on the server)
MTXFOIL_VERSION=latest
MEDIAMTX_IMAGE_TAG=latest
# GHCR stack only (PORTAINER_STACK.ghcr.yml):
# MTXFOIL_IMAGE_REGISTRY=ghcr.io/silvansan
# Git branch/tag for baseline mediamtx.yml seed on first deploy
MTXFOIL_CONFIG_REF=main
# Override only when using a fork: owner/repo
# MTXFOIL_REPO=silvansan/MTXfoil

DASHBOARD_PORT=3000
WORKER_CONCURRENCY=2

# Host port bindings — only the left side of each mapping changes (e.g. RTMP_PORT=1940
# binds host 1940 → container 1935). MediaMTX still listens on 1935/1936 inside the container.
# If a default port is already in use on the host, set the variable and remove/redeploy the
# stack so Docker releases old bindings. Check all of these for conflicts:
#   3000 (dashboard), 1935/1936 (RTMP/RTMPS), 8554 (RTSP), 8888 (HLS), 8889 (WebRTC), 8189/8890 (ICE/SRT)
RTMP_PORT=1935
RTMPS_PORT=1936
RTSP_PORT=8554
HLS_PORT=8888
WEBRTC_HTTP_PORT=8889
WEBRTC_ICE_PORT=8189
SRT_PORT=8890
