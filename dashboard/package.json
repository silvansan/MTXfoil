{
  "name": "mtxfoil-dashboard",
  "version": "0.1.0",
  "description": "MTXfoil — MediaMTX control panel (Payload CMS + operator UI)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:openapi": "openapi-typescript https://raw.githubusercontent.com/bluenviron/mediamtx/main/api/openapi.yaml -o src/lib/mediamtx/openapi-types.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-slot": "^1.2.3",
    "bull": "^4.16.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.525.0",
    "next": "15.4.11",
    "next-themes": "^0.4.6",
    "payload": "3.84.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "video.js": "^8.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "22.19.9",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "openapi-typescript": "^7.8.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": "^20.9.0 || >=22"
  }
}
